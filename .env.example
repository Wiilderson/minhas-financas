# Crie em https://console.cloud.google.com
# Ative: Google Sheets API
# Credenciais > ID do cliente OAuth 2.0 > Aplicativo da Web
VITE_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# ID da planilha (parte da URL entre /d/ e /edit)
# Ex: https://docs.google.com/spreadsheets/d/ESTE_ID_AQUI/edit
VITE_SPREADSHEET_ID=

# Nome da aba (opcional). Se vazio, usa a primeira aba que não seja "Lancamentos"
# Ex: Página 3
VITE_SHEET_TAB_NAME=Página 3
